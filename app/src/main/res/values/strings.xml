    <!-- HelpScreen -->
    <string name="help_title">Ayuda</string>
    <string name="help_subtitle">Encuentra respuesta a las dudas más habituales o escríbenos directamente.</string>
    <string name="help_section_faq">Preguntas frecuentes</string>
    <string name="help_section_contact">¿No encuentras lo que buscas?</string>
    <string name="help_contact_body">Escríbenos y te respondemos en menos de 24 horas.</string>
    <string name="help_contact_email">soporte@zesta.app</string>

    <string name="help_faq_1_q">¿Cómo hago mi primer pedido?</string>
    <string name="help_faq_1_a">Elige un restaurante, añade productos al carrito y pulsa \"Hacer pedido\". Necesitas tener dirección y teléfono guardados en tu perfil.</string>
    <string name="help_faq_2_q">¿Puedo cancelar un pedido?</string>
    <string name="help_faq_2_a">Puedes cancelarlo en los primeros 2 minutos. Pasado ese tiempo el restaurante ya lo habrá visto y no es posible cancelar desde la app.</string>
    <string name="help_faq_3_q">¿Cómo funciona el envío gratis?</string>
    <string name="help_faq_3_a">Algunos restaurantes lo ofrecen sin coste. Cuando sea así verás la etiqueta \"Envío gratis\" en su tarjeta.</string>
    <string name="help_faq_4_q">¿Cómo cambio mi dirección de entrega?</string>
    <string name="help_faq_4_a">Entra en tu perfil, toca \"Gestionar direcciones\" y selecciona o añade la que quieras. También puedes cambiarlo antes de confirmar el pedido.</string>
    <string name="help_faq_5_q">Tengo un problema con mi pedido, ¿qué hago?</string>
    <string name="help_faq_5_a">Escríbenos al correo de soporte indicando tu número de pedido. Lo revisamos lo antes posible.</string>
    <string name="help_faq_6_q">¿Puedo usar la app sin cuenta?</string>
    <string name="help_faq_6_a">Sí, en modo invitado puedes explorar restaurantes y ver sus cartas. Para pedir y guardar favoritos necesitas registrarte.</string>

    <!-- PrivacyScreen -->
    <string name="privacy_title">Política de privacidad</string>
    <string name="privacy_last_updated">Última actualización: abril de 2026</string>
    <string name="privacy_s1_title">1. Datos que recopilamos</string>
    <string name="privacy_s1_body">Recopilamos los datos que nos proporcionas al registrarte (nombre, email, teléfono, dirección) y los necesarios para gestionar tus pedidos. También recogemos datos de uso anónimos para mejorar la experiencia.</string>
    <string name="privacy_s2_title">2. Cómo usamos tus datos</string>
    <string name="privacy_s2_body">Usamos tus datos para gestionar tu cuenta, procesar pedidos y enviarte confirmaciones. No los usamos para publicidad de terceros sin tu consentimiento.</string>
    <string name="privacy_s3_title">3. Compartición de datos</string>
    <string name="privacy_s3_body">Solo compartimos los datos necesarios con los restaurantes que preparan tus pedidos y con nuestros proveedores de infraestructura (Firebase/Google). No vendemos tus datos a terceros.</string>
    <string name="privacy_s4_title">4. Tus derechos (RGPD)</string>
    <string name="privacy_s4_body">Tienes derecho a acceder, rectificar y eliminar tus datos en cualquier momento desde tu perfil o contactando con nosotros. También puedes deshabilitar tu cuenta desde Ajustes.</string>
    <string name="privacy_s5_title">5. Seguridad</string>
    <string name="privacy_s5_body">Los datos se almacenan en Firebase con cifrado en tránsito (TLS) y en reposo. Las contraseñas nunca se guardan en texto plano.</string>
    <string name="privacy_s6_title">6. Contacto</string>
    <string name="privacy_s6_body">Para cualquier consulta sobre privacidad escríbenos a:</string>
    <string name="privacy_dpo_email">privacidad@zesta.app</string>

